  function updCtr(){ if(ctr) ctr.textContent = (idx+1)+' / '+PHOTOS.length; }
  function goSlide(i) {
    slides[idx].classList.remove('on');
    if(dotEls[idx]) dotEls[idx].classList.remove('on');
    idx = ((i%slides.length)+slides.length)%slides.length;
    slides[idx].classList.add('on');
    if(dotEls[idx]) dotEls[idx].classList.add('on');
    updCtr(); resetAp();
  }
  function resetAp(){ clearInterval(ap); ap = setInterval(function(){ goSlide(idx+1); }, 5800); }
  prev.addEventListener('click', function(){ goSlide(idx-1); });
  next.addEventListener('click', function(){ goSlide(idx+1); });
  var sx = 0;
  track.addEventListener('touchstart', function(e){ sx=e.touches[0].clientX; },{passive:true});
  track.addEventListener('touchend', function(e){ var dx=e.changedTouches[0].clientX-sx; if(Math.abs(dx)>40){ goSlide(dx<0?idx+1:idx-1); } },{passive:true});
  document.addEventListener('keydown', function(e){
    if(document.getElementById('lb').classList.contains('open')) return;
    if(e.key==='ArrowLeft') goSlide(idx-1);
    if(e.key==='ArrowRight') goSlide(idx+1);
  });
  updCtr(); resetAp();
  var lb = document.getElementById('lb');
  var lbImg = document.getElementById('lb-img');
  var lbCnt = document.getElementById('lb-cnt');
  function openLb(i){ lbIdx=i; lbImg.src=du(PHOTOS[lbIdx],2400); lbCnt.textContent=(lbIdx+1)+' / '+PHOTOS.length; lb.classList.add('open'); document.body.style.overflow='hidden'; }
  function closeLb(){ lb.classList.remove('open'); document.body.style.overflow=''; }
  function lbGo(i){ lbIdx=((i%PHOTOS.length)+PHOTOS.length)%PHOTOS.length; lbImg.src=du(PHOTOS[lbIdx],2400); lbCnt.textContent=(lbIdx+1)+' / '+PHOTOS.length; }
  document.getElementById('lb-close').addEventListener('click', closeLb);
  document.getElementById('lb-prev').addEventListener('click', function(e){ e.stopPropagation(); lbGo(lbIdx-1); });
  document.getElementById('lb-next').addEventListener('click', function(e){ e.stopPropagation(); lbGo(lbIdx+1); });
  lb.addEventListener('click', function(e){ if(e.target===lb||e.target===lbImg) closeLb(); });
  document.addEventListener('keydown', function(e){
    if(!lb.classList.contains('open')) return;
    if(e.key==='Escape') closeLb();
    if(e.key==='ArrowLeft') lbGo(lbIdx-1);
    if(e.key==='ArrowRight') lbGo(lbIdx+1);
  });
})();

